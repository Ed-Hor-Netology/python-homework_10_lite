# Создаем функцию для преобразования строки в целое число
def convert_to_int(value):

    try:
        # Пытаемся преобразовать значение в целое число
        number = int(value)

        # Если преобразование прошло успешно, выводим результат
        print(f"Преобразование выполнено успешно: {number}")

        # Возвращаем полученное число
        return number

    except ValueError:
        # Эта ошибка возникает, если строку нельзя преобразовать в число
        print("Ошибка: невозможно преобразовать значение в целое число.")

    except Exception as error:
        # Обработка любых других ошибок
        print(f"Неожиданная ошибка: {error}")

    finally:
        # Этот блок выполняется всегда,
        # независимо от того, возникла ошибка или нет
        print("Попытка преобразования завершена.\n")
# Проверка функции
convert_to_int("123")
# Некорректная строка
convert_to_int("abc")
# Список вместо строки
convert_to_int([1, 2, 3])